<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>МИРоКИТ | Культурно-игровой триатлон</title>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Montserrat',sans-serif;
}

body{
background:#f8fafc;
color:#1e293b;
line-height:1.6;
}

.container{
width:90%;
max-width:1200px;
margin:auto;
}

header{
position:fixed;
width:100%;
top:0;
left:0;
background:rgba(255,255,255,0.95);
backdrop-filter:blur(12px);
z-index:1000;
box-shadow:0 2px 15px rgba(0,0,0,0.05);
}

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 0;
}

.logo{
font-size:28px;
font-weight:800;
color:#2563eb;
}

.menu{
display:flex;
gap:30px;
}

.menu a{
text-decoration:none;
color:#334155;
font-weight:500;
transition:0.3s;
}

.menu a:hover{
color:#2563eb;
}

.hero{
min-height:100vh;
background:linear-gradient(135deg,#2563eb,#7c3aed);
display:flex;
align-items:center;
color:white;
padding-top:80px;
}

.hero-content{
display:grid;
grid-template-columns:1fr 1fr;
gap:60px;
align-items:center;
}

.hero h1{
font-size:70px;
font-weight:800;
line-height:1;
margin-bottom:20px;
}

.hero h2{
font-size:24px;
font-weight:400;
margin-bottom:30px;
}

.hero p{
font-size:18px;
margin-bottom:40px;
opacity:.95;
}

.btn{
display:inline-block;
padding:16px 34px;
background:white;
color:#2563eb;
border-radius:50px;
font-weight:700;
text-decoration:none;
transition:0.3s;
}

.btn:hover{
transform:translateY(-3px);
}

.hero-card{
background:rgba(255,255,255,.15);
padding:40px;
border-radius:25px;
backdrop-filter:blur(20px);
}

.hero-card h3{
font-size:30px;
margin-bottom:15px;
}

.section{
padding:100px 0;
}

.section-title{
text-align:center;
font-size:42px;
font-weight:800;
margin-bottom:60px;
}

.about{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:30px;
}

.card{
background:white;
padding:35px;
border-radius:20px;
box-shadow:0 10px 30px rgba(0,0,0,.06);
transition:.3s;
}

.card:hover{
transform:translateY(-10px);
}

.card h3{
margin-bottom:15px;
color:#2563eb;
}

.mission{
background:white;
}

.mission-content{
max-width:900px;
margin:auto;
text-align:center;
font-size:20px;
}

.goals{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.goal{
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 5px 20px rgba(0,0,0,.05);
}

.goal h4{
margin-bottom:10px;
color:#7c3aed;
}

.structure{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:30px;
}

.structure-box{
background:white;
padding:35px;
border-radius:20px;
box-shadow:0 5px 25px rgba(0,0,0,.05);
}

.structure-box h3{
margin-bottom:20px;
color:#2563eb;
}

.structure-box ul{
padding-left:20px;
}

.structure-box li{
margin-bottom:10px;
}

.stats{
background:linear-gradient(135deg,#2563eb,#7c3aed);
color:white;
}

.stats-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
}

.stat{
text-align:center;
padding:30px;
}

.stat h3{
font-size:48px;
margin-bottom:10px;
}

.leader{
display:flex;
gap:50px;
align-items:center;
background:white;
padding:50px;
border-radius:25px;
box-shadow:0 10px 30px rgba(0,0,0,.05);
}

.avatar{
width:180px;
height:180px;
border-radius:50%;
background:linear-gradient(135deg,#2563eb,#7c3aed);
}

footer{
background:#0f172a;
color:white;
padding:60px 0;
text-align:center;
}

footer h3{
margin-bottom:20px;
}

@media(max-width:900px){

.hero-content,
.structure,
.about,
.leader{
grid-template-columns:1fr;
display:grid;
}

.hero h1{
font-size:50px;
}

.menu{
display:none;
}

}

</style>
</head>

